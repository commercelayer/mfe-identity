{
  "name": "mfe-identity",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/commercelayer/mfe-identity.git"
  },
  "author": {
    "name": "Pier Francesco Ferrari",
    "email": "pierfrancesco@commercelayer.io"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/commercelayer/mfe-identity/issues"
  },
  "homepage": "https://github.com/commercelayer/mfe-identity#readme",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "preview": "pnpm -r preview",
    "start": "pnpm -r start",
    "check": "pnpm -r check",
    "check:fix": "pnpm -r check:fix",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:e2e": "pnpm -r test:e2e",
    "test:e2e:ui": "pnpm -r test:e2e:ui",
    "test:e2e:debug": "pnpm -r test:e2e:debug",
    "dep:major": "pnpm dlx npm-check-updates --packageFile '**/package.json' -u",
    "dep:minor": "pnpm dlx npm-check-updates -t semver --packageFile '**/package.json' -u",
    "prepare": "husky",
    "clean": "pnpx rimraf --glob **/node_modules **/pnpm-lock.yaml"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^20.0.0"
  }
}
