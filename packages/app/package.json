{
  "name": "mfe-identity",
  "private": true,
  "version": "1.7.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "description": "A Commerce Layer Single Page Application to provide login and signup.",
  "repository": {
    "type": "git",
    "url": "https://github.com/commercelayer/mfe-identity.git"
  },
  "author": {
    "name": "Pier Francesco Ferrari",
    "email": "pierfrancesco@commercelayer.io"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/commercelayer/mfe-identity/issues"
  },
  "homepage": "https://github.com/commercelayer/mfe-identity#readme",
  "keywords": [
    "reactjs",
    "jamstack",
    "headless",
    "ecommerce",
    "identity",
    "login",
    "signup",
    "commercelayer"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "tsc && vite build",
    "start": "vite --host 0.0.0.0 --port $PORT preview",
    "preview": "vite preview",
    "check": "pnpm biome check",
    "check:fix": "pnpm biome check --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "touch ./public/config.local.js"
  },
  "dependencies": {
    "@commercelayer/js-auth": "6.7.2",
    "@commercelayer/sdk": "^6.56.0",
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "v2.1.10",
    "@tailwindcss/forms": "^0.5.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/iframe-resizer": "^4.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "24.12.2",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/react-helmet": "6.1.11",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "classnames": "^2.5.1",
    "i18next": "^25.10.10",
    "lodash": "^4.18.1",
    "only-allow": "^1.2.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-helmet-async": "2.0.5",
    "react-hook-form": "7.71.2",
    "react-i18next": "^15.7.4",
    "tailwindcss": "^3.4.19",
    "wouter": "^3.9.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "type-fest": "^4.41.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.2"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
